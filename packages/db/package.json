{
  "name": "@match/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "node prisma-with-api-env.cjs generate --schema prisma/schema.prisma",
    "db:migrate": "node prisma-with-api-env.cjs migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "node prisma-with-api-env.cjs migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "prisma": "^6.19.2",
    "typescript": "^5.9.3"
  }
}
