generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchRole {
  SELLER
  MANAGER
  DESIGNER
  AD_BUYER
  EXPERT
  PRODUCTION
  FULFILLMENT
  CARGO
  ANALYTICS_SERVICE
  LOGISTIC
  BLOGGER
  ACCOUNTANT
  LAWYER
  PRODUCT_SOURCER
  CUSTOM
}

enum SwipeDirection {
  LIKE
  PASS
}

model User {
  id              String       @id @default(cuid())
  telegramId      String       @unique
  telegramUsername String?
  displayName     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  profile         MatchProfile?
}

model MatchProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            MatchRole
  roleCustom      String?
  displayName     String
  headline        String?
  bio             String?
  city            String?
  niches          String[]
  skills          String[]
  priceMin        Int?
  priceMax        Int?
  currency        String          @default("RUB")
  avatarUrl       String?
  portfolioUrl    String?
  telegramContact String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  settings        MatchSettings?
  swipesFrom      MatchSwipe[]    @relation("SwipesFrom")
  swipesTo        MatchSwipe[]    @relation("SwipesTo")
  messagesSent    MatchMessage[]  @relation("MessageSender")

  @@index([role])
  @@index([isActive])
}

model MatchSettings {
  id               String       @id @default(cuid())
  profileId        String       @unique
  profile          MatchProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  interestedRoles  MatchRole[]
  interestedNiches String[]
  hideFromFeed     Boolean      @default(false)
  updatedAt        DateTime     @updatedAt
}

model MatchSwipe {
  id            String         @id @default(cuid())
  fromProfileId String
  fromProfile   MatchProfile   @relation("SwipesFrom", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfileId   String
  toProfile     MatchProfile   @relation("SwipesTo", fields: [toProfileId], references: [id], onDelete: Cascade)
  direction     SwipeDirection
  createdAt     DateTime       @default(now())

  @@unique([fromProfileId, toProfileId])
  @@index([fromProfileId])
  @@index([toProfileId])
}

model MatchPair {
  id         String         @id @default(cuid())
  profileAId String
  profileBId String
  createdAt  DateTime       @default(now())
  messages   MatchMessage[]

  @@unique([profileAId, profileBId])
  @@index([profileAId])
  @@index([profileBId])
}

model MatchMessage {
  id              String       @id @default(cuid())
  pairId          String
  pair            MatchPair    @relation(fields: [pairId], references: [id], onDelete: Cascade)
  senderProfileId String
  senderProfile   MatchProfile @relation("MessageSender", fields: [senderProfileId], references: [id], onDelete: Cascade)
  body            String
  createdAt       DateTime     @default(now())

  @@index([pairId, createdAt])
}
