{
  "name": "match-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @match/api --filter @match/web run dev",
    "build": "pnpm -r --filter @match/db --filter @match/api --filter @match/web run build",
    "lint": "pnpm -r --filter @match/api --filter @match/web run lint",
    "test": "pnpm -r --filter @match/api --filter @match/web run test",
    "db:generate": "node packages/db/prisma-with-api-env.cjs generate --schema prisma/schema.prisma",
    "db:migrate": "node packages/db/prisma-with-api-env.cjs migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "node packages/db/prisma-with-api-env.cjs migrate deploy --schema prisma/schema.prisma",
    "deploy:server": "bash ./scripts/deploy-pull-build.sh"
  }
}
