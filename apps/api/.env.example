PORT=3001
NODE_ENV=production

# DATABASE_URL: для Prisma стоит явно задать размер пула — по умолчанию
# connection_limit = num_cpus * 2 + 1, что на small VPS = 5..9 коннектов, и под
# пиками (polling /matches × N вкладок + тяжёлый $queryRaw в /feed) упрёмся
# в pool_timeout. 15 достаточно для 1 API-инстанса; при использовании
# pgbouncer в transaction mode также добавьте ?pgbouncer=true.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/match_app?connection_limit=15&pool_timeout=10

APP_BASE_URL=https://match.example.com
MATCH_MINIAPP_URL=https://match.example.com/m

MATCH_BOT_TOKEN=
# Optional proxy for Telegram Bot API requests (for blocked routes / egress limits)
# TELEGRAM_HTTP_PROXY=http://127.0.0.1:7890
MATCH_JWT_SECRET=
ADMIN_EMAILS=
ADMIN_WEB_PASSWORD_HASH=
MATCH_CORS_ORIGINS=https://match.example.com,https://t.me
MATCH_UPLOADS_DIR=/var/www/match-app/apps/api/storage/match-media

# Local dev auth bypass (no Telegram initData required)
MATCH_DEV_AUTH_BYPASS=0
MATCH_DEV_TELEGRAM_ID=match-dev-local-telegram-id
MATCH_DEV_TELEGRAM_USERNAME=match_dev_local
MATCH_DEV_DISPLAY_NAME=Match Local Dev

# Match mini-app: feature flags и параметры второй фазы
MATCH_FEATURE_RANKING=1
MATCH_FEATURE_STREAKS=1
MATCH_FEATURE_DIGEST=1
MATCH_FEATURE_PENDING_LIKES=1
# Activity × reciprocity scoring (docs/CURSOR_TASKS_ACTIVITY_SCORE.md).
# Master flag: enables the nightly cron and the private profile section.
MATCH_FEATURE_RECIPROCITY=0
# Sub-flags for independent rollout of downstream consumers.
MATCH_RECIPROCITY_BADGES=0
MATCH_RECIPROCITY_RANKING=0
MATCH_LIKE_LIMIT_PER_DAY=30
MATCH_UNDO_COOLDOWN_SECONDS=600
MATCH_SWIPE_RESET_COOLDOWN_DAYS=14
MATCH_AUTO_SWIPE_RESET=1
MATCH_AUTO_RESET_INACTIVITY_THRESHOLD_DAYS=60
MATCH_PAUSE_MAX_DAYS=90
MATCH_DIGEST_MIN_FRESH=3

# Invite-only mode.
# По умолчанию (переменная не задана или =1/true/yes) режим ВКЛЮЧЁН —
# регистрация возможна только по инвайт-коду. Чтобы открыть публичную
# регистрацию, выстави явно MATCH_INVITE_ONLY=0 (или false/no/off).
# Любая опечатка = invite-only остаётся включённым (fail-safe).
MATCH_INVITE_ONLY=1
# Пользователи с этими username'ами могут регистрироваться без кода.
# Список через запятую, lowercase.
MATCH_INVITE_BYPASS_USERNAMES=alantsoff
